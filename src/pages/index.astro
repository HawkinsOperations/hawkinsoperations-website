---
import BaseLayout from "@layouts/BaseLayout.astro";
import BrandMark from "@components/BrandMark.astro";
import PortraitCommandFrame from "@components/PortraitCommandFrame.astro";
import StatusChip from "@components/StatusChip.astro";
import ArtifactCard from "@components/ArtifactCard.astro";
import ReceiptCard from "@components/ReceiptCard.astro";
import SectionEyebrow from "@components/SectionEyebrow.astro";
import ProofCeilingDisplay from "@components/ProofCeilingDisplay.astro";
import TruthSurfaceSeparation from "@components/TruthSurfaceSeparation.astro";
import { credibilityMetrics } from "@data/credibilityMetrics";
import { externalLinks } from "@data/navigation";
import { reviewerRoutes } from "@data/reviewerRoutes";
import { artifacts, type Artifact } from "@data/artifacts";

const previewSlugs = [
  "ho-det-001-proof-record",
  "aws-det-001-proof-record",
  "ho-det-001-lab-runtime-match",
  "cribl-to-splunk-marker-delivery",
  "synthetic-validation-boundary",
  "blocked-claim-scanner",
];
const previewArtifacts = previewSlugs
  .map((slug) => artifacts.find((a) => a.slug === slug))
  .filter((a): a is Artifact => a !== undefined);

const reviewerSnapshot = [
  {
    title: "Work exists",
    body: "Detection source, validation artifacts, proof records, and controlled lab receipts are separated by plane.",
  },
  {
    title: "Proof is bounded",
    body: "Synthetic validation and private/internal receipts do not silently become public runtime claims.",
  },
  {
    title: "AI is labor",
    body: "AI can support drafting and triage, but deterministic checks and CI own claim promotion.",
  },
];

const loopReceipts = [
  {
    title: "HO-DET-001 Synthetic Validation",
    surface: "Validation",
    statusBadge: "TEST_VALIDATED_SYNTHETIC_SCOPE",
    publicSafe: true,
    claim: "HO-DET-001 passed synthetic validation against controlled positive and negative process-creation fixtures.",
    boundary: "Does not prove runtime activity, signal observation, fleet scope, or public-safe runtime proof.",
    nextGate: "Runtime + public-safe evidence review remain separate.",
    href: externalLinks.validationReportHo,
    hrefLabel: "Validation report ↗",
  },
  {
    title: "HO-DET-001 Controlled Lab Runtime Match",
    surface: "Runtime",
    statusBadge: "PROVEN_PRIVATE_INTERNAL",
    publicSafe: false,
    claim: "HO-DET-001 produced a controlled lab runtime match in Splunk.",
    boundary: "Does not prove runtime-active deployment, public-safe runtime proof, fleet-wide coverage, Cribl-routed telemetry, Wazuh-routed public proof, AWS-live status, autonomous SOC operation, or live Splunk fired as public proof.",
    nextGate: "Privacy review · evidence linkage · stale review · Raylee approval.",
    href: externalLinks.proofRecord + "#controlled-runtime-signal-packet-001",
    hrefLabel: "Proof record ↗",
  },
  {
    title: "Cribl-to-Splunk Marker Delivery",
    surface: "Evidence",
    statusBadge: "CONTROLLED_LAB_CRIBL_TO_SPLUNK_MARKER_DELIVERY_VERIFIED",
    publicSafe: false,
    claim: "A controlled clean remote marker was delivered through the Cribl-to-Splunk lab lane and observed in expected Splunk rawdata with marker fields preserved.",
    boundary: "Does not prove HO-DET-001/Sysmon telemetry is Cribl-routed, does not prove Cribl-routed telemetry for production or fleet scope, and does not change the public proof ceiling.",
    nextGate: "HO-DET-001 / Sysmon field-preservation comparison remains separate.",
    href: externalLinks.proofRecord + "#controlled-cribl-to-splunk-marker-delivery-packet-001",
    hrefLabel: "Proof record ↗",
  },
  {
    title: "AWS-DET-001 Cloud Fixture Validation",
    surface: "Validation",
    statusBadge: "TEST_VALIDATED_SYNTHETIC_SCOPE",
    publicSafe: false,
    claim: "AWS-DET-001 passed fixture-only validation against controlled CloudTrail-style IAM denial fixtures.",
    boundary: "Does not prove AWS-live, CloudTrail live, cloud runtime-active, signal-observed, or public-safe runtime proof.",
    nextGate: "Live AWS surface remains blocked until separately approved.",
    href: externalLinks.validationReportAws,
    hrefLabel: "Validation report ↗",
  },
];
---

<BaseLayout
  title="HawkinsOperations Detection Engineering SOC"
  description="HawkinsOperations is a governed detection engineering system that turns security work into validated, bounded proof. Reviewer-facing surface separating source, validation, runtime, signal, evidence, and public claims."
>
  <!-- ╔══ HERO · Moonlit proof command surface ═══════════════════════════════ -->
  <section class="relative overflow-hidden">
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <div class="absolute inset-0 opacity-[0.16]" style="background-image: linear-gradient(to right, rgba(201,211,223,0.06) 1px, transparent 1px), linear-gradient(to bottom, rgba(201,211,223,0.06) 1px, transparent 1px); background-size: 64px 64px; mask-image: radial-gradient(ellipse at 50% 30%, black 0%, transparent 75%);"></div>
      <div class="absolute -top-40 -left-40 size-[640px] rounded-full" style="background: radial-gradient(circle, rgba(143,216,255,0.08), transparent 60%); filter: blur(20px);"></div>
    </div>

    <div class="container relative grid gap-14 pt-14 pb-20 lg:grid-cols-[1.1fr_0.9fr] lg:pt-24 lg:pb-28 lg:gap-16">
      <!-- LEFT · headline column · ALWAYS first in flow -->
      <div class="order-1 flex flex-col">
        <div class="flex flex-wrap items-center gap-2">
          <StatusChip label="PUBLIC REVIEWER SURFACE" tone="ice" />
          <StatusChip label="AI · LABOR" />
          <span class="mono text-[0.6rem] tracking-[0.22em] uppercase text-[var(--muted)]">v · 2026-05</span>
        </div>

        <h1 class="headline mt-7 text-[clamp(2.4rem,5.6vw,4.4rem)] tracking-tight">
          HawkinsOperations
          <span class="block text-[var(--ice-blue)]">Detection Engineering SOC</span>
        </h1>

        <p class="lede mt-7 max-w-2xl">
          HawkinsOperations is a governed detection engineering system that turns security work into validated, bounded proof.
        </p>
        <p class="muted mt-4 max-w-2xl text-base leading-7">
          Speeding up security production without letting the system lie.
        </p>

        <!-- CTA row · primary + single secondary; org and operator links live in nav/footer -->
        <div class="mt-9 flex flex-wrap items-center gap-3">
          <a class="cta cta-primary" href="/proof/">Review Proof →</a>
          <a class="cta cta-quiet" href="/start/">Start Here →</a>
        </div>

        <!-- Hero proof ceiling micro-panel -->
        <aside class="hero-ceiling mt-10 max-w-xl">
          <div class="hero-ceiling__inner">
            <p class="hero-ceiling__eyebrow mono">Current public proof ceiling</p>
            <div class="hero-ceiling__display">
              <ProofCeilingDisplay visualLabel="Synthetic Validation Scope" />
            </div>
            <p class="hero-ceiling__note">
              Website rendering is routing only. Stronger runtime, signal, and evidence claims remain blocked until separately promoted.
            </p>
          </div>
        </aside>
      </div>

      <!-- RIGHT · Portrait (editorial) · second in flow on narrow, right column on wide -->
      <div class="order-2 flex items-center justify-center lg:justify-end">
        <div class="hero-identity-panel" aria-label="HawkinsOperations brand identity">
          <BrandMark size="lg" />
          <div>
            <p class="hero-identity-panel__wordmark">HawkinsOperations</p>
            <p class="hero-identity-panel__line mono">Proof &gt; Truth &gt; Authority</p>
          </div>
          <PortraitCommandFrame size="compact" showArc={false} />
        </div>
      </div>
    </div>

    <div class="container"><hr class="thin-rule" /></div>
  </section>

  <!-- ╔══ REVIEWER SNAPSHOT · 3 cards · what to understand first ═════════════ -->
  <section class="container section-tight" aria-labelledby="reviewer-snapshot-title">
    <header class="mb-7 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="eyebrow">Reviewer snapshot</p>
        <h2 id="reviewer-snapshot-title" class="headline mt-2 text-2xl md:text-[1.7rem]">What reviewers should understand first</h2>
      </div>
    </header>
    <ul class="snapshot-grid" aria-label="Reviewer snapshot">
      {reviewerSnapshot.map((item, i) => (
        <li class="snapshot-card">
          <span class="snapshot-card__num mono">{`0${i + 1}`}</span>
          <h3 class="snapshot-card__title">{item.title}</h3>
          <p class="snapshot-card__body">{item.body}</p>
        </li>
      ))}
    </ul>
  </section>

  <!-- ╔══ CREDIBILITY STRIP · repo-derived surface counts only ═══════════════ -->
  <section class="container section-tight" aria-labelledby="credibility-metrics-title">
    <div class="surface-coverage">
      <header class="surface-coverage__header">
        <p class="eyebrow">Surface coverage, not runtime activity</p>
        <h2 id="credibility-metrics-title" class="headline mt-2 text-2xl md:text-[1.7rem]">Reviewer-visible routes are counted from repo data.</h2>
      </header>
      <ul class="surface-coverage__grid" aria-label="Repository-derived surface coverage">
        {credibilityMetrics.map((metric) => (
          <li class="surface-coverage__tile">
            <span class="surface-coverage__value mono">{metric.value}</span>
            <span class="surface-coverage__label">{metric.label}</span>
            <span class="surface-coverage__footnote">{metric.footnote}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ╔══ EXECUTIVE SUMMARY ═══════════════════════════════════════════════════ -->
  <section class="container section-tight" aria-labelledby="executive-summary-title">
    <div class="executive-summary moon-panel-strong p-6 md:p-8">
      <div class="executive-summary__intro">
        <p class="eyebrow">Plain English</p>
        <h2 id="executive-summary-title" class="headline mt-3 text-2xl md:text-3xl">Executive Summary</h2>
        <p class="lede mt-5">
          I build and verify detection engineering workflows where the code, tests, evidence, and public claims are kept separate so the system can move fast without overstating what is proven.
        </p>
      </div>
      <ul class="executive-summary__list" aria-label="Executive summary capabilities">
        <li>Builds detection engineering proof loops.</li>
        <li>Validates detections with controlled fixtures.</li>
        <li>Uses AI only as support, not authority.</li>
        <li>Uses deterministic checks and CI to block unsupported claims.</li>
        <li>Keeps private lab evidence separate from public proof.</li>
        <li>Lets reviewers clone/run public validators where possible.</li>
      </ul>
      <div class="executive-summary__chips" aria-label="Governance shorthand">
        <span>TEST_VALIDATED_SYNTHETIC_SCOPE</span>
        <span>Website rendering is not proof</span>
        <span>AI is labor</span>
        <span>Governance is authority</span>
      </div>
    </div>
  </section>

  <!-- ╔══ DETERMINISTIC SCANNER · visible trust strip ════════════════════════ -->
  <section class="container section-tight" aria-labelledby="scanner-strip-title">
    <div class="scanner-trust-strip">
      <p class="eyebrow" id="scanner-strip-title">DETERMINISTIC SCANNER</p>
      <p>Site wording is checked by a deterministic blocked-claim scanner. This does not prove runtime control coverage or branch protection.</p>
    </div>
  </section>

  <!-- ╔══ REVIEWER ROUTES · three inline inspection paths ════════════════════ -->
  <section class="container section-tight" aria-labelledby="review-depth-title">
    <div class="review-depth-header">
      <div>
        <p class="eyebrow">Inspection paths</p>
        <h2 id="review-depth-title" class="headline mt-2 text-2xl md:text-[1.7rem]">Choose your review depth</h2>
        <p class="muted mt-3 text-sm leading-6 max-w-xl">
          Pick the depth that fits the review window and follow the proof from the same public ceiling.
        </p>
      </div>
      <a class="surface-link-label surface-link-label--primary review-depth-header__link" href="/start/">Open full reviewer route →</a>
    </div>
    <ul class="review-route-grid" aria-label="Review depths">
      {reviewerRoutes.map((route) => (
        <li class="review-route-card">
          <span class="review-route-card__duration mono">{route.duration}</span>
          <h3>{route.title}</h3>
          <p>{route.purpose}</p>
          <div class="review-route-card__links">
            {route.links.slice(0, 3).map((link) => (
              <a href={link.href} target={link.external ? "_blank" : undefined} rel={link.external ? "noopener noreferrer" : undefined}>
                {link.label}{link.external ? " ↗" : ""}
              </a>
            ))}
          </div>
        </li>
      ))}
    </ul>
  </section>

  <!-- ╔══ FLAGSHIP PROOF ROUTE · HO-DET-001 visible path ═════════════════════ -->
  <section class="container section-tight" aria-labelledby="flagship-proof-route-title">
    <div class="flagship-spread homepage-flagship">
      <div class="flagship-spread__rail">
        <p class="eyebrow">Flagship proof route</p>
        <div>
          <h2 id="flagship-proof-route-title" class="headline text-3xl md:text-4xl">HO-DET-001 · Closed SOC loop</h2>
          <p class="muted mt-4 text-base leading-7">Splunk detection → validation → proof record → blocked claims → next gate</p>
        </div>
        <div class="homepage-flagship__status mono">TEST_VALIDATED_SYNTHETIC_SCOPE</div>
      </div>
      <div class="flagship-spread__body">
        <dl class="homepage-flagship__claims">
          <div>
            <dt>Proves</dt>
            <dd>Controlled synthetic validation at TEST_VALIDATED_SYNTHETIC_SCOPE.</dd>
          </div>
          <div>
            <dt>Does not prove</dt>
            <dd>Does not prove runtime-active deployment, signal observation, fleet scope, production, or public-safe runtime proof.</dd>
          </div>
          <div>
            <dt>Next gate</dt>
            <dd>Privacy review · evidence linkage · stale review · Raylee approval.</dd>
          </div>
        </dl>
        <div class="homepage-flagship__actions">
          <a class="cta cta-primary" href="/proof/ho-det-001/">Open proof record</a>
          <a class="cta cta-quiet" href={externalLinks.validationReportHo} target="_blank" rel="noopener noreferrer">Open validation report ↗</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ╔══ CONTROLLED LOOP RECEIPTS · routed by claim boundary ════════════════ -->
  <section class="container section-tight" aria-labelledby="controlled-loop-receipts-title">
    <header class="mb-7 flex flex-wrap items-end justify-between gap-3">
      <div class="max-w-2xl">
        <p class="eyebrow">Controlled Loop Receipts</p>
        <h2 id="controlled-loop-receipts-title" class="headline mt-2 text-2xl md:text-[1.7rem]">Receipts are routed by claim boundary.</h2>
        <p class="muted mt-3 text-sm leading-6">
          Stronger claims stay blocked until separately promoted. Private/internal receipts carry a NOT_PUBLIC_SAFE badge and do not promote public-runtime wording.
        </p>
      </div>
    </header>
    <div class="receipt-grid">
      {loopReceipts.map((receipt) => (
        <ReceiptCard
          title={receipt.title}
          surface={receipt.surface}
          statusBadge={receipt.statusBadge}
          publicSafe={receipt.publicSafe}
          claim={receipt.claim}
          boundary={receipt.boundary}
          nextGate={receipt.nextGate}
          href={receipt.href}
          hrefLabel={receipt.hrefLabel}
        />
      ))}
    </div>
  </section>

  <!-- ╔══ TRUTH SURFACE SEPARATION ════════════════════════════════════════════ -->
  <section class="container section-tight">
    <TruthSurfaceSeparation />
  </section>

  <!-- ╔══ TRUTH RAIL ═══════════════════════════════════════════════════════════ -->

  <!-- ╔══ CLOSED LOOP PREVIEW ══════════════════════════════════════════════════ -->

  <!-- ╔══ ARTIFACT VAULT PREVIEW ═══════════════════════════════════════════════ -->
  <section class="container section-tight proof-cta-block">
    <SectionEyebrow
      eyebrow="Artifact / proof route"
      title="Open the receipts, then follow the record."
      description="Proof records, validation outputs, CI verifier records, and public packets each carry their own ceiling and proof boundary."
      align="between"
      cta={{ label: "Open the full vault", href: "/artifacts/" }}
    />
    <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {previewArtifacts.map((artifact) => (
        <ArtifactCard artifact={artifact} variant={artifact.flagship ? "flagship" : "default"} />
      ))}
    </div>
  </section>

  <!-- ╔══ BLOCKED CLAIM STRIP ══════════════════════════════════════════════════ -->

  <!-- ╔══ CLOSING DOCTRINE ═════════════════════════════════════════════════════ -->
  <section class="container py-16 quiet-text-section">
    <div class="moon-panel relative overflow-hidden p-8 md:p-10">
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute -right-20 -top-20 size-[360px] rounded-full" style="background: radial-gradient(circle, rgba(143,216,255,0.1), transparent 60%); filter: blur(20px);"></div>
      </div>
      <div class="relative grid gap-8 md:grid-cols-[1.4fr_1fr] md:items-center">
        <div>
          <p class="eyebrow">Doctrine</p>
          <h2 class="headline mt-3 text-3xl md:text-4xl">AI is labor. Governance is authority.</h2>
          <p class="muted mt-4 max-w-2xl text-base leading-7">
            Build loud. Verify hard. Claim tight. Ship receipts. The system separates the work AI can accelerate from the gates that decide what HawkinsOperations is allowed to claim publicly.
          </p>
        </div>
        <div class="flex flex-wrap items-center gap-3 md:justify-end">
          <a class="cta cta-primary" href="/about/">Operator profile →</a>
          <a class="cta cta-quiet" href="/proof/">Proof ledger</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
