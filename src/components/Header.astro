---
import BrandMark from "@components/BrandMark.astro";
import { primaryNavigation, externalLinks } from "@data/navigation";

const path = Astro.url.pathname.replace(/\/$/, "") || "/";

const isCurrent = (href: string) => {
  const normalized = href.replace(/\/$/, "") || "/";
  if (normalized === "/") return path === "/";
  return path === normalized || path.startsWith(normalized + "/");
};
---

<header class="site-header sticky top-0 z-40 border-b border-[var(--moon-border)] bg-[rgba(0,2,5,0.86)] backdrop-blur-md">
  <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-[var(--ice-blue-soft)] to-transparent"></div>
  <div class="container flex min-h-[68px] items-center justify-between gap-5">
    <a href="/" class="group flex items-center gap-3" aria-label="HawkinsOperations home">
      <BrandMark size="sm" />
      <span class="flex flex-col leading-tight">
        <span class="text-sm font-semibold text-[var(--silver-bright)]">HawkinsOperations</span>
        <span class="mono text-[0.58rem] uppercase tracking-[0.22em] text-[var(--muted)]">Detection Engineering SOC</span>
      </span>
    </a>

    <nav class="hidden items-center gap-7 md:flex" aria-label="Primary navigation">
      {primaryNavigation.map((item) => (
        <a
          class="nav-link"
          href={item.href}
          aria-current={isCurrent(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a class="hidden md:inline-flex cta cta-quiet" href={externalLinks.githubOrg} target="_blank" rel="noopener noreferrer" aria-label="Open the HawkinsOperations GitHub organization">
        GitHub Org
      </a>
    </div>
  </div>

  <nav class="md:hidden border-t border-[var(--moon-border)]" aria-label="Primary navigation mobile">
    <div class="container flex items-center gap-5 overflow-x-auto py-3">
      {primaryNavigation.map((item) => (
        <a
          class="nav-link shrink-0"
          href={item.href}
          aria-current={isCurrent(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>
