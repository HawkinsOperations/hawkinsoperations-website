---
export interface Props {
  label: string;
  value: string;
  detail?: string;
  tone?: "default" | "safe" | "warn" | "block";
  dataTarget?: string;
}

const { label, value, detail, tone = "default", dataTarget } = Astro.props;
const toneClass = {
  default: "border-slate-700/70",
  safe: "border-blue-100/30",
  warn: "border-yellow-300/35",
  block: "border-rose-300/35",
}[tone];
---

<article class={`card p-5 ${toneClass}`} data-ci-target={dataTarget}>
  <p class="mono text-xs uppercase text-slate-500">{label}</p>
  <p class="mt-3 text-lg font-semibold text-slate-100">{value}</p>
  {detail && <p class="mt-3 text-sm leading-6 text-slate-400">{detail}</p>}
</article>
