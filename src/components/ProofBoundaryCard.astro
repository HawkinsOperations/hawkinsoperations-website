---
import StatusChip from "./StatusChip.astro";

export interface Props {
  label: string;
  value: string;
  detail?: string;
  tone?: "default" | "ice" | "warn" | "block";
  chip?: { label: string; tone?: "default" | "ice" | "warn" | "block" | "quiet" };
}

const { label, value, detail, tone = "default", chip } = Astro.props;

const ringClass = {
  default: "border-[var(--moon-border)]",
  ice: "border-[rgba(143,216,255,0.32)]",
  warn: "border-[rgba(250,204,21,0.32)]",
  block: "border-[rgba(251,113,133,0.32)]",
}[tone];
---

<article class={`moon-panel relative p-6 ${ringClass}`}>
  <p class="mono text-[0.65rem] tracking-[0.18em] uppercase text-[var(--silver)]">{label}</p>
  <p class="mt-3 text-lg font-semibold text-[var(--silver-bright)] leading-snug">{value}</p>
  {detail && <p class="mt-3 text-sm leading-6 text-[var(--muted)]">{detail}</p>}
  {chip && (
    <div class="mt-4">
      <StatusChip label={chip.label} tone={chip.tone} />
    </div>
  )}
</article>
