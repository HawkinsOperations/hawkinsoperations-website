---
export interface Props {
  size?: "sm" | "md" | "lg";
  label?: string;
}

const { size = "md", label = "HawkinsOperations" } = Astro.props;
---

<span class={`brand-mark brand-mark--${size}`} aria-label={label} role="img">
  <picture>
    <source srcset="/brand/hawkinsoperations-mark-runtime-1024.avif" type="image/avif" />
    <source srcset="/brand/hawkinsoperations-mark-runtime-1024.webp" type="image/webp" />
    <img src="/brand/hawkinsoperations-mark-source.png" alt="" width="512" height="512" loading="eager" decoding="async" />
  </picture>
</span>

<style>
  .brand-mark picture {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
