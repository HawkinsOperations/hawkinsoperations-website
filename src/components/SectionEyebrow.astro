---
export interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "start" | "between";
  cta?: { label: string; href: string };
}

const { eyebrow, title, description, align = "start", cta } = Astro.props;
---

<header class={`mb-10 flex ${align === "between" ? "flex-wrap items-end justify-between gap-6" : "flex-col gap-3"}`}>
  <div class="max-w-3xl">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h2 class="headline mt-3 text-3xl md:text-4xl text-[var(--silver-bright)]">{title}</h2>
    {description && <p class="muted mt-4 text-base leading-7">{description}</p>}
  </div>
  {cta && align === "between" && (
    <a class="cta cta-quiet" href={cta.href}>{cta.label} →</a>
  )}
</header>
