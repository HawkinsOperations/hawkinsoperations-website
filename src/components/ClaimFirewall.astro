---
import { allowedClaims, blockedClaims, promotionRequirements, safeWordingExamples, unsafeWordingExamples } from "@data/claims";
---

<div class="grid gap-5 lg:grid-cols-2" data-ci-target="blocked-claims">
  <article class="surface rounded-lg p-6">
    <p class="mono text-xs uppercase text-blue-100">Allowed claims</p>
    <ul class="mt-5 space-y-3 text-sm leading-6 text-slate-300">
      {allowedClaims.map((claim) => <li>{claim}</li>)}
    </ul>
  </article>
  <article class="surface rounded-lg border-rose-300/25 p-6">
    <p class="mono text-xs uppercase text-rose-200">Blocked / not claimed</p>
    <div class="mt-5 flex flex-wrap gap-2">
      {blockedClaims.map((claim) => (
        <span class="mono border border-rose-300/25 bg-rose-950/30 px-2.5 py-1 text-[0.68rem] uppercase text-rose-100">{claim}</span>
      ))}
    </div>
  </article>
  <article class="card p-6">
    <p class="mono text-xs uppercase text-slate-500">Promotion requirements</p>
    <ul class="mt-5 space-y-3 text-sm leading-6 text-slate-300">
      {promotionRequirements.map((item) => <li>{item}</li>)}
    </ul>
  </article>
  <article class="card p-6">
    <p class="mono text-xs uppercase text-slate-500">Wording examples</p>
    <div class="mt-5 grid gap-4">
      <div>
        <h3 class="text-sm font-semibold text-blue-100">Safe wording</h3>
        <ul class="mt-2 space-y-2 text-sm leading-6 text-slate-400">
          {safeWordingExamples.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-rose-200">Unsafe wording</h3>
        <ul class="mt-2 space-y-2 text-sm leading-6 text-slate-400">
          {unsafeWordingExamples.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </article>
</div>
