---
import { externalLinks, primaryNavigation, reviewerLinks } from "@data/navigation";
---

<footer class="site-footer hairline mt-12">
  <div class="container grid gap-8 py-9 sm:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
    <div class="sm:col-span-2 lg:col-span-1">
      <div class="flex items-center gap-3">
        <span class="relative grid size-8 place-items-center border border-[var(--moon-border-bright)] bg-[rgba(11,17,28,0.7)]">
          <span class="absolute inset-[3px] border border-[rgba(143,216,255,0.25)]"></span>
          <span class="mono text-[0.58rem] font-bold tracking-[0.16em] text-[var(--ice-blue)]">HO</span>
        </span>
        <div class="flex flex-col leading-tight">
          <span class="text-sm font-semibold text-[var(--silver-bright)]">HawkinsOperations</span>
          <span class="mono text-[0.55rem] uppercase tracking-[0.22em] text-[var(--muted)]">Detection Engineering SOC</span>
        </div>
      </div>
      <p class="muted mt-4 max-w-md text-[0.86rem] leading-6">
        Public reviewer surface for governed detection engineering and AI-assisted SOC production. Website rendering is not proof.
      </p>
      <p class="mono mt-4 text-[0.64rem] uppercase tracking-[0.18em] text-[var(--muted)]">
        Build loud · Verify hard · Claim tight · Ship receipts
      </p>
    </div>

    <div>
      <p class="mono text-[0.58rem] uppercase tracking-[0.2em] text-[var(--silver)]">Primary surface</p>
      <ul class="mt-3 grid gap-1.5 text-[0.86rem] text-[var(--muted)]">
        {primaryNavigation.map((item) => (
          <li><a class="hover:text-[var(--ice-blue)]" href={item.href}>{item.label}</a></li>
        ))}
      </ul>
      <p class="mono mt-5 text-[0.58rem] uppercase tracking-[0.2em] text-[var(--silver)]">Operator</p>
      <ul class="mt-3 grid gap-1.5 text-[0.86rem] text-[var(--muted)]">
        <li><a class="hover:text-[var(--ice-blue)]" href={externalLinks.rayleeGithub} target="_blank" rel="noopener noreferrer">GitHub ↗</a></li>
        <li><a class="hover:text-[var(--ice-blue)]" href={externalLinks.rayleeLinkedIn} target="_blank" rel="noopener noreferrer">LinkedIn ↗</a></li>
      </ul>
    </div>

    <div>
      <p class="mono text-[0.58rem] uppercase tracking-[0.2em] text-[var(--silver)]">Reviewer routes</p>
      <ul class="mt-3 grid gap-1.5 text-[0.86rem] text-[var(--muted)]">
        {reviewerLinks.map((item) => (
          <li><a class="hover:text-[var(--ice-blue)]" href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <p class="mono text-[0.58rem] uppercase tracking-[0.2em] text-[var(--silver)]">Repositories</p>
      <ul class="mt-3 grid gap-1.5 text-[0.86rem] text-[var(--muted)]">
        <li><a class="hover:text-[var(--ice-blue)]" href={externalLinks.githubOrg} target="_blank" rel="noopener noreferrer">GitHub organization ↗</a></li>
        <li><a class="hover:text-[var(--ice-blue)]" href={externalLinks.detections} target="_blank" rel="noopener noreferrer">Detections ↗</a></li>
        <li><a class="hover:text-[var(--ice-blue)]" href={externalLinks.validation} target="_blank" rel="noopener noreferrer">Validation ↗</a></li>
        <li><a class="hover:text-[var(--ice-blue)]" href={externalLinks.proof} target="_blank" rel="noopener noreferrer">Proof ↗</a></li>
        <li><a class="hover:text-[var(--ice-blue)]" href={externalLinks.controlMatrix} target="_blank" rel="noopener noreferrer">Control matrix ↗</a></li>
        <li><a class="hover:text-[var(--ice-blue)]" href={externalLinks.repoAuthorityMap} target="_blank" rel="noopener noreferrer">Repo authority map ↗</a></li>
        <li><a class="hover:text-[var(--ice-blue)]" href={externalLinks.legacyHawkinsOps} target="_blank" rel="noopener noreferrer">Legacy HawkinsOps ↗</a></li>
      </ul>
    </div>
  </div>

  <div class="hairline">
    <div class="container flex flex-wrap items-center justify-between gap-3 py-4 text-[0.7rem] text-[var(--muted)]">
      <span>© Raylee Hawkins · HawkinsOperations Detection Engineering SOC</span>
      <span class="mono uppercase tracking-[0.18em]">Public reviewer surface</span>
    </div>
  </div>
</footer>
