---
import BrandMark from "@components/BrandMark.astro";
import { externalLinks, primaryNavigation, reviewerLinks } from "@data/navigation";
---

<footer class="site-footer hairline mt-12">
  <div class="container grid gap-10 py-12 sm:grid-cols-2 lg:grid-cols-[1.5fr_1fr_1fr_1fr] lg:gap-12">
    <div class="sm:col-span-2 lg:col-span-1">
      <div class="flex items-center gap-3.5">
        <BrandMark size="md" />
        <div class="flex flex-col leading-tight">
          <span class="text-[0.95rem] font-semibold text-[var(--silver-bright)]">HawkinsOperations</span>
          <span class="mono text-[0.58rem] uppercase tracking-[0.22em] text-[var(--silver)]">Detection Engineering SOC</span>
        </div>
      </div>
      <p class="site-footer__lede mt-5 max-w-md text-[0.88rem] leading-7">
        Public reviewer surface for governed detection engineering. Website rendering is not proof.
      </p>
      <p class="mono mt-5 text-[0.64rem] uppercase tracking-[0.2em] text-[var(--silver)]">
        Build loud · Verify hard · Claim tight · Ship receipts
      </p>
    </div>

    <div>
      <p class="site-footer__heading mono">Primary surface</p>
      <ul class="site-footer__list mt-4">
        {primaryNavigation.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
      <p class="site-footer__heading mono mt-7">Operator</p>
      <ul class="site-footer__list mt-4">
        <li><a href={externalLinks.rayleeGithub} target="_blank" rel="noopener noreferrer">GitHub ↗</a></li>
        <li><a href={externalLinks.rayleeLinkedIn} target="_blank" rel="noopener noreferrer">LinkedIn ↗</a></li>
      </ul>
    </div>

    <div>
      <p class="site-footer__heading mono">Reviewer routes</p>
      <ul class="site-footer__list mt-4">
        {reviewerLinks.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <p class="site-footer__heading mono">Repositories</p>
      <ul class="site-footer__list mt-4">
        <li><a href={externalLinks.githubOrg} target="_blank" rel="noopener noreferrer">GitHub organization ↗</a></li>
        <li><a href={externalLinks.detections} target="_blank" rel="noopener noreferrer">Detections ↗</a></li>
        <li><a href={externalLinks.validation} target="_blank" rel="noopener noreferrer">Validation ↗</a></li>
        <li><a href={externalLinks.proof} target="_blank" rel="noopener noreferrer">Proof ↗</a></li>
        <li><a href={externalLinks.controlMatrix} target="_blank" rel="noopener noreferrer">Control matrix ↗</a></li>
        <li><a href={externalLinks.repoAuthorityMap} target="_blank" rel="noopener noreferrer">Repo authority map ↗</a></li>
        <li><a href={externalLinks.legacyHawkinsOps} target="_blank" rel="noopener noreferrer">Legacy HawkinsOps ↗</a></li>
      </ul>
    </div>
  </div>

  <div class="hairline">
    <div class="container flex flex-wrap items-center justify-between gap-3 py-5 text-[0.72rem] text-[var(--silver)]">
      <span>© Raylee Hawkins · HawkinsOperations Detection Engineering SOC</span>
      <span class="mono uppercase tracking-[0.18em]">Public reviewer surface</span>
    </div>
  </div>
</footer>
