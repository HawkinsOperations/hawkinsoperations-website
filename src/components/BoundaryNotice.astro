---
export interface Props {
  title?: string;
  text?: string;
}

const {
  title = "Boundary notice",
  text = "Website rendering is not proof.",
} = Astro.props;
---

<aside class="border-l-2 border-emerald-300 bg-emerald-300/8 px-5 py-4">
  <p class="mono text-xs uppercase text-emerald-200">{title}</p>
  <p class="mt-2 text-sm leading-6 text-slate-200">{text}</p>
</aside>
