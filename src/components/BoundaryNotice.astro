---
export interface Props {
  title?: string;
  text?: string;
}

const {
  title = "Boundary notice",
  text = "Website rendering is not proof.",
} = Astro.props;
---

<aside class="border-l-2 border-blue-100/50 bg-blue-100/[0.045] px-5 py-4">
  <p class="mono text-xs uppercase text-blue-100">{title}</p>
  <p class="mt-2 text-sm leading-6 text-slate-200">{text}</p>
</aside>
