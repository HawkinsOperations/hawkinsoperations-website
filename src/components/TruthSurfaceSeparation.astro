---
type SurfaceSlug = "source" | "validation" | "runtime" | "signal" | "evidence" | "public-proof";

const surfaces: {
  slug: SurfaceSlug;
  name: string;
  question: string;
  canProve: string;
  cannotProve: string;
  example: string;
  lane: string;
  stages: string[];
}[] = [
  {
    slug: "source",
    name: "Source",
    question: "Where does the work enter the system?",
    canProve: "A detection source, SPL, or rule candidate exists and can be reviewed.",
    cannotProve: "The rule executed, matched, or produced a signal.",
    example: "HO-DET-001 detection source",
    lane: "Closed SOC Loop",
    stages: ["Detection Source"],
  },
  {
    slug: "validation",
    name: "Validation",
    question: "Did controlled fixtures exercise the behavior?",
    canProve: "Positive and negative fixtures passed inside the validation boundary.",
    cannotProve: "Endpoint runtime activity, production scope, or fleet coverage.",
    example: "HO-DET-001 validation report",
    lane: "Synthetic validation lane",
    stages: ["Fixtures", "Case Packet"],
  },
  {
    slug: "runtime",
    name: "Runtime",
    question: "Did the system execute in a lab or runtime environment?",
    canProve: "A bounded local runtime event or execution path exists when separately evidenced.",
    cannotProve: "Public-safe signal or public proof by itself.",
    example: "Sanitized internal runtime packet when approved",
    lane: "Runtime boundary lane",
    stages: ["Case Packet", "Verifier"],
  },
  {
    slug: "signal",
    name: "Signal",
    question: "Was an event, match, or correlation observed?",
    canProve: "A bounded observed event exists when the evidence chain is approved.",
    cannotProve: "Production, fleet-wide, or public-safe status.",
    example: "Signal receipt after privacy and claim review",
    lane: "Signal boundary lane",
    stages: ["Verifier", "Proof Record"],
  },
  {
    slug: "evidence",
    name: "Evidence",
    question: "What receipt supports the reviewer decision?",
    canProve: "A packet, hash, CI output, or reviewer artifact exists.",
    cannotProve: "Public wording or promotion without the claim gate.",
    example: "Case packet and blocked-claim scanner output",
    lane: "Governance review gate",
    stages: ["AI Support", "Verifier"],
  },
  {
    slug: "public-proof",
    name: "Public Proof",
    question: "What can the public page safely route to?",
    canProve: "A reviewed public proof record exists with a stated ceiling.",
    cannotProve: "Raw runtime truth, signal observation, or stronger status by website rendering alone.",
    example: "HO-DET-001 public proof record",
    lane: "Website reviewer surface",
    stages: ["Proof Record", "Claim Ceiling"],
  },
];
---

<section class="truth-board" aria-labelledby="truth-board-title">
  <header class="truth-board__header">
    <div>
      <p class="eyebrow">Truth Surface Control Board</p>
      <h2 id="truth-board-title" class="headline mt-3 text-2xl md:text-[1.8rem]">
        Select one surface. Inspect its boundary before the claim moves.
      </h2>
      <p class="truth-board__plain mt-3">
        These controls highlight matching lanes and conveyor gates. They do not promote proof.
        Website rendering remains reviewer routing only.
      </p>
    </div>
    <button
      type="button"
      class="truth-board__reset"
      data-surface-reset
      aria-label="Show all surfaces and clear the active filter"
    >
      Show all
    </button>
  </header>

  <div class="truth-board__switches" role="tablist" aria-label="Truth surfaces">
    {surfaces.map((surface, index) => (
      <button
        type="button"
        class="truth-board__switch"
        data-surface-filter={surface.slug}
        data-surface-tab={surface.slug}
        data-surface-label={surface.name}
        role="tab"
        aria-selected={index === 0 ? "true" : "false"}
        aria-pressed="false"
        aria-controls={`truth-panel-${surface.slug}`}
      >
        <span class="truth-board__switch-index mono">{String(index + 1).padStart(2, "0")}</span>
        <span>{surface.name}</span>
      </button>
    ))}
  </div>

  <div class="truth-board__workspace">
    <ol class="truth-board__rail" aria-label="Separated control surfaces">
      {surfaces.map((surface, index) => (
        <li class="truth-board__rail-item" data-surface-marker={surface.slug}>
          <span class="truth-board__rail-index mono">{String(index + 1).padStart(2, "0")}</span>
          <span class="truth-board__rail-label">{surface.name}</span>
        </li>
      ))}
    </ol>

    <div class="truth-board__panels">
      {surfaces.map((surface, index) => (
        <article
          class="truth-board__panel"
          id={`truth-panel-${surface.slug}`}
          data-surface-panel={surface.slug}
          role="tabpanel"
          hidden={index !== 0}
        >
          <div class="truth-board__panel-head">
            <p class="truth-board__surface mono">{surface.slug}</p>
            <h3>{surface.name}</h3>
            <p>{surface.question}</p>
          </div>

          <dl class="truth-board__facts">
            <div>
              <dt>Can prove</dt>
              <dd>{surface.canProve}</dd>
            </div>
            <div>
              <dt>Cannot prove</dt>
              <dd>{surface.cannotProve}</dd>
            </div>
            <div>
              <dt>Example artifact</dt>
              <dd>{surface.example}</dd>
            </div>
            <div>
              <dt>Matching lane</dt>
              <dd>{surface.lane}</dd>
            </div>
            <div class="truth-board__stages">
              <dt>Related conveyor gates</dt>
              <dd>
                {surface.stages.map((stage) => <span>{stage}</span>)}
              </dd>
            </div>
          </dl>
        </article>
      ))}
    </div>
  </div>

  <p class="truth-board__status mono" aria-live="polite" data-surface-status>
    Filter inactive · all surfaces shown.
  </p>
</section>

<script>
  type SurfaceTarget = HTMLElement;

  const buttons = document.querySelectorAll<HTMLButtonElement>("[data-surface-filter]");
  const resetButtons = document.querySelectorAll<HTMLButtonElement>("[data-surface-reset]");
  const statusLabels = document.querySelectorAll<HTMLElement>("[data-surface-status]");
  const panels = document.querySelectorAll<HTMLElement>("[data-surface-panel]");
  const markers = document.querySelectorAll<HTMLElement>("[data-surface-marker]");

  function targets(): NodeListOf<SurfaceTarget> {
    return document.querySelectorAll<SurfaceTarget>("[data-surface]");
  }

  function surfaceLabel(surface: string): string {
    return (
      Array.from(buttons).find((button) => button.dataset.surfaceFilter === surface)?.dataset.surfaceLabel ||
      surface
    );
  }

  function setStatus(surface: string | null) {
    statusLabels.forEach((el) => {
      el.textContent = surface
        ? `Filter active · ${surfaceLabel(surface)} surface highlighted.`
        : "Filter inactive · all surfaces shown.";
    });
  }

  function setPanel(surface: string) {
    buttons.forEach((button) => {
      const on = button.dataset.surfaceTab === surface;
      button.setAttribute("aria-selected", on ? "true" : "false");
      button.classList.toggle("is-selected", on);
    });

    panels.forEach((panel) => {
      panel.hidden = panel.dataset.surfacePanel !== surface;
    });

    markers.forEach((marker) => {
      marker.classList.toggle("is-selected", marker.dataset.surfaceMarker === surface);
    });
  }

  function applyFilter(surface: string | null) {
    buttons.forEach((button) => {
      const on = !!surface && button.dataset.surfaceFilter === surface;
      button.setAttribute("aria-pressed", on ? "true" : "false");
      button.classList.toggle("is-active", on);
    });

    targets().forEach((el) => {
      if (!surface) {
        el.classList.remove("is-surface-dim", "is-surface-match");
        return;
      }

      const declared = (el.dataset.surface || "").split(/\s+/).filter(Boolean);
      if (declared.includes(surface)) {
        el.classList.add("is-surface-match");
        el.classList.remove("is-surface-dim");
      } else {
        el.classList.add("is-surface-dim");
        el.classList.remove("is-surface-match");
      }
    });

    if (surface) {
      document.body.dataset.activeSurface = surface;
    } else {
      delete document.body.dataset.activeSurface;
    }

    setStatus(surface);
  }

  buttons.forEach((button) => {
    button.addEventListener("click", () => {
      const next = button.dataset.surfaceFilter;
      if (!next) return;

      setPanel(next);

      if (document.body.dataset.activeSurface === next) {
        applyFilter(null);
      } else {
        applyFilter(next);
      }
    });
  });

  resetButtons.forEach((button) => button.addEventListener("click", () => applyFilter(null)));

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && document.body.dataset.activeSurface) {
      applyFilter(null);
    }
  });

  setPanel("source");
  applyFilter(null);
</script>
