---
const planes = [
  {
    name: "Source",
    canProve: "Detection source and SPL exist.",
    cannotProve: "A live event fired.",
  },
  {
    name: "Validation",
    canProve: "Controlled fixtures passed.",
    cannotProve: "Endpoint runtime activity.",
  },
  {
    name: "Runtime",
    canProve: "System execution in the lab.",
    cannotProve: "Public-safe signal by itself.",
  },
  {
    name: "Signal",
    canProve: "Event, match, or correlation observed.",
    cannotProve: "Production or fleet scope.",
  },
  {
    name: "Evidence",
    canProve: "Receipt, hash, export, or packet exists.",
    cannotProve: "Public wording by itself.",
  },
  {
    name: "Public Proof",
    canProve: "Reviewed public claim boundary.",
    cannotProve: "Raw runtime truth by rendering alone.",
  },
];
---

<section class="truth-separation moon-panel relative overflow-hidden p-6 md:p-8" aria-labelledby="truth-separation-title">
  <div class="truth-separation__header">
    <div>
      <p class="eyebrow">Truth Surface Separation</p>
      <h2 id="truth-separation-title" class="headline mt-3 text-2xl md:text-[1.7rem]">
        Six surfaces. Each answers a different question.
      </h2>
    </div>
    <p class="truth-separation__plain">
      None inherits proof from another. A passing fixture, lab receipt, or rendered page cannot silently become a stronger public claim.
    </p>
  </div>

  <ol class="truth-separation__steps" aria-label="Separated truth planes">
    {planes.map((plane, index) => (
      <li class={`truth-plane truth-plane--${index + 1}`}>
        <div class="truth-plane__rail">
          <span class="truth-plane__index">{String(index + 1).padStart(2, "0")}</span>
        </div>
        <div class="truth-plane__body">
          <h3>{plane.name}</h3>
          <dl>
            <div>
              <dt>Can prove</dt>
              <dd>{plane.canProve}</dd>
            </div>
            <div>
              <dt>Cannot prove</dt>
              <dd>{plane.cannotProve}</dd>
            </div>
          </dl>
        </div>
      </li>
    ))}
  </ol>
</section>
