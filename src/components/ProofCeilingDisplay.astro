---
import { proofCeiling } from "@data/claims";

export interface Props {
  size?: "default" | "xl";
  visualLabel?: string;
}

const { size = "default", visualLabel } = Astro.props;

// Render the machine token as visual editorial words to avoid mid-token wrap.
const defaultVisual = "Controlled · Test · Validated";
const visual = visualLabel ?? defaultVisual;
---

<div class={`ceiling-display ${size === "xl" ? "ceiling-display--xl" : ""}`}>
  <p class="ceiling-display__visual">{visual}</p>
  <p class="ceiling-display__token" title={proofCeiling}>{proofCeiling}</p>
</div>
